table fact_blood_pressure
	lineageTag: b81155f8-99f0-41ae-8851-e2a466c9e982

	measure 'Avg Systolic' = AVERAGE ( fact_blood_pressure[mean_systolic] )
		formatString: 0.0
		lineageTag: 4757d36a-939d-4958-810b-7ba30b761468

	measure 'Avg Diastolic' = AVERAGE ( fact_blood_pressure[mean_diastolic] )
		formatString: 0.0
		lineageTag: e4c5c255-c6cc-43dc-8108-a800fef779da

	column SEQN
		dataType: int64
		lineageTag: 976cddbf-67d5-4f15-8b6d-accbbea79326
		sourceColumn: SEQN
		summarizeBy: none

	column mean_systolic
		dataType: double
		lineageTag: bbf6d561-d252-4065-a62c-eb07d76464d6
		sourceColumn: mean_systolic
		summarizeBy: sum

	column mean_systolic_zscore
		dataType: double
		lineageTag: 520c256b-45b9-4daf-9741-bac04e5aff9a
		sourceColumn: mean_systolic_zscore
		summarizeBy: sum

	column mean_systolic_is_outlier
		dataType: boolean
		lineageTag: 43ab5977-bb60-4893-a757-ffea44614c5f
		sourceColumn: mean_systolic_is_outlier
