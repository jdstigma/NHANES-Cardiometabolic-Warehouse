		lineageTag: 59475571-88d8-46f4-b0b1-b6f6f6c8d7a5
		sourceColumn: mean_diastolic
		summarizeBy: sum

	column mean_diastolic_zscore
		dataType: double
		lineageTag: 2904baaf-d67e-4a5b-8a93-584ddc5edeed
