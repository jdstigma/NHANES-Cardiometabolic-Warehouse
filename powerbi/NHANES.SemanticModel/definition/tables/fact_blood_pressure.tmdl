		summarizeBy: sum

	column mean_diastolic_is_outlier
		dataType: boolean
		lineageTag: 8b417c15-7877-4659-b6d9-2b5d75d38a97
		sourceColumn: mean_diastolic_is_outlier
		summarizeBy: none

	partition fact_blood_pressure = m
		mode: import
		source =
			let
				Source = Csv.Document(File.Contents(ExportsFolder & "fact_blood_pressure.csv"), [Delimiter=",", Columns=7, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				Typed = Table.TransformColumnTypes(Promoted, {{"SEQN", Int64.Type}, {"mean_systolic", type number}, {"mean_systolic_zscore", type number}, {"mean_systolic_is_outlier", type logical}, {"mean_diastolic", type number}, {"mean_diastolic_zscore", type number}, {"mean_diastolic_is_outlier", type logical}})
			in
				Typed
