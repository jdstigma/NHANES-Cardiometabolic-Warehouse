	partition fact_labs = m
		mode: import
		source =
			let
				Source = Csv.Document(File.Contents(ExportsFolder & "fact_labs.csv"), [Delimiter=",", Columns=22, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				Typed = Table.TransformColumnTypes(Promoted, {{"SEQN", Int64.Type}, {"total_cholesterol", type number}, {"total_cholesterol_zscore", type number}, {"total_cholesterol_is_outlier", type logical}, {"hdl_cholesterol", type number}, {"hdl_cholesterol_zscore", type number}, {"hdl_cholesterol_is_outlier", type logical}, {"triglycerides", type number}, {"triglycerides_zscore", type number}, {"triglycerides_is_outlier", type logical}, {"ldl_cholesterol", type number}, {"ldl_cholesterol_zscore", type number}, {"ldl_cholesterol_is_outlier", type logical}, {"fasting_glucose", type number}, {"fasting_glucose_zscore", type number}, {"fasting_glucose_is_outlier", type logical}, {"hba1c", type number}, {"hba1c_zscore", type number}, {"hba1c_is_outlier", type logical}, {"insulin", type number}, {"insulin_zscore", type number}, {"insulin_is_outlier", type logical}})
			in
				Typed
