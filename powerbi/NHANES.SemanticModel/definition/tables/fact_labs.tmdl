table fact_labs
	lineageTag: 7c350d48-1b75-4cd9-89ae-eecb705c7279

	measure 'HbA1c Measured' = COUNTROWS ( FILTER ( fact_labs, NOT ( ISBLANK ( fact_labs[hba1c] ) ) ) )
		lineageTag: b9b63ba8-43a4-4cb3-a7e3-eb91eedf8e83

	measure 'Prediabetes Rate' = DIVIDE ( COUNTROWS ( FILTER ( fact_labs, fact_labs[hba1c] >= 5.7 && fact_labs[hba1c] < 6.5 ) ), [HbA1c Measured] )
		formatString: 0.0%
		lineageTag: 456455ea-b997-4cff-a222-2f450e765704

	measure 'Diabetic-Range Rate' = DIVIDE ( COUNTROWS ( FILTER ( fact_labs, fact_labs[hba1c] >= 6.5 ) ), [HbA1c Measured] )
		formatString: 0.0%
		lineageTag: 1aa8ae2f-418e-413e-ad82-ec72f72024c6

	measure 'Avg Fasting Glucose' = AVERAGE ( fact_labs[fasting_glucose] )
		formatString: 0.0
		lineageTag: 078ace7d-d46f-4bb2-bf16-83d2c3cb0027

	measure 'Avg HbA1c' = AVERAGE ( fact_labs[hba1c] )
		formatString: 0.00
		lineageTag: 28cf44a9-8caf-40ea-83b2-8db8bf670483

	measure 'Avg LDL' = AVERAGE ( fact_labs[ldl_cholesterol] )
		formatString: 0.0
		lineageTag: 5e90257a-4604-4a41-b65e-0dd596ade32d

