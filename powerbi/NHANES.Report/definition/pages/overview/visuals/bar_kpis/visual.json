{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "bar_kpis",
  "position": {
    "x": 20,
    "y": 160,
    "z": 4000,
    "width": 610,
    "height": 540,
    "tabOrder": 4000
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "metrics_summary"
                    }
                  },
                  "Property": "metric"
                }
              },
              "queryRef": "metrics_summary.metric",
              "nativeQueryRef": "metric"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "metrics_summary"
                    }
                  },
                  "Property": "Metric Value"
                }
              },
              "queryRef": "metrics_summary.Metric Value",
              "nativeQueryRef": "Metric Value"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Measure": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "metrics_summary"
                  }
                },
                "Property": "Metric Value"
              }
            },
            "direction": "Descending"
          }
        ]
      }
    },
    "drillFilterOtherVisuals": true
  }
}