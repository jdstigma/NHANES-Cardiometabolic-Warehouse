{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "bar_anom_by_gender",
  "position": {
    "x": 650,
    "y": 440,
    "z": 5000,
    "width": 610,
    "height": 260,
    "tabOrder": 5000
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_respondents"
                    }
                  },
                  "Property": "gender"
                }
              },
              "queryRef": "dim_respondents.gender",
              "nativeQueryRef": "gender"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "fact_anomalies"
                    }
                  },
                  "Property": "Flagged Anomalies"
                }
              },
              "queryRef": "fact_anomalies.Flagged Anomalies",
              "nativeQueryRef": "Flagged Anomalies"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true
  }
}